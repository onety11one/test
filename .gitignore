### C#
# Build results
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# User-specific files
*.suo
*.user

# Debug symbols
*.pdb

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# .NET build artifacts
artifacts/

# Publish output
publish/

### Unity
# Unity generated directories
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emory[Cc]aptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Build output
*.apk
*.aab
*.unitypackage

# Autogenerated solution and project files
*.csproj
*.unityproj
*.sln
*.suo

### Windows
# Windows thumbnail cache files
Thumbs.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

### JetBrains
# JetBrains IDE directory
.idea/

# CMake build directories
cmake-build-*/

# File-based project format
*.iws
*.iml

# IntelliJ build output
out/

### Unity Package Manager
# No need to track .asset files in these folders
/Assets/Packages/
/Assets/Plugins/

### .gitattributes
# Unity should be configured to use UnityYAMLMerge
* text=auto

